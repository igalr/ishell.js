{
  "name": "ishell.js",
  "version": "1.3.1",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "hide": "rm -rf dist && tsup src/* --format cjs,esm --dts --minify",
    "dev": "nodemon --exec node dist/local.js",
    "start": "node dist/local.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.758.0",
    "@aws-sdk/credential-providers": "^3.758.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mime-types": "^3.0.2",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.11",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
